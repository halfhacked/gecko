# pre-commit: run unit tests for both mac-client and web-dashboard

set -euo pipefail

echo "==> [pre-commit] Running unit tests..."

# Mac client tests
cd apps/mac-client
xcodebuild test \
  -project Gecko.xcodeproj \
  -scheme GeckoTests \
  -destination 'platform=macOS' \
  -quiet \
  2>&1 | tail -5
cd ../..

# Web dashboard tests (with coverage gate — enforces bunfig.toml thresholds)
cd apps/web-dashboard
bun test --coverage src/__tests__/ --timeout 30000 2>&1 | tail -20
cd ../..

echo "==> [pre-commit] Tests passed."
