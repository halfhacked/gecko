# Web: G1 (typecheck + lint-staged) → L1 (unit tests + coverage)
# Mac:  G1 (swiftlint --strict) → L1 (xcodebuild test)
# Run in parallel, fail if either fails

(cd apps/web-dashboard && bun run typecheck && bun run lint:staged && bun run test:coverage) &
PID_WEB=$!

(cd apps/mac-client && swiftlint --strict && xcodebuild test -project Gecko.xcodeproj -scheme Gecko -destination 'platform=macOS' -only-testing:GeckoTests -quiet) &
PID_MAC=$!

FAIL=0
wait $PID_WEB || FAIL=1
wait $PID_MAC || FAIL=1

exit $FAIL
