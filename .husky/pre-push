# D1: Verify test database isolation (_test_marker check)
# L2: API E2E (integration tests)
# G2: Security gate (osv-scanner + gitleaks)
# L2 & G2 run in parallel after D1 verification passes

cd apps/web-dashboard

bun run verify:test-db || exit 1

bun run test:e2e &
PID_L2=$!

bun run gate:security &
PID_G2=$!

FAIL=0
wait $PID_L2 || FAIL=1
wait $PID_G2 || FAIL=1

exit $FAIL
