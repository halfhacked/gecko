{
  "name": "gecko-web",
  "version": "1.8.3",
  "description": "Gecko screen time dashboard",
  "type": "module",
  "scripts": {
    "dev": "vinext dev --port 7018",
    "build": "vinext build",
    "start": "vinext start --port 7018",
    "dev:e2e": "E2E_SKIP_AUTH=true CF_D1_DATABASE_ID_TEST=38cf80a4-be1b-4532-8781-f9b2ef706578 vinext dev --port 17018",
    "typecheck": "tsc --noEmit",
    "lint": "eslint --max-warnings 0",
    "lint:staged": "lint-staged",
    "test": "bun test src/__tests__/ --timeout 30000 --path-ignore-patterns '**/bdd/**'",
    "test:coverage": "bun run scripts/check-coverage.ts",
    "test:e2e": "RUN_E2E=true bun test --env-file=.env --env-file=.env.e2e src/__tests__/e2e/ --timeout 60000",
    "dev:bdd": "E2E_SKIP_AUTH=true CF_D1_DATABASE_ID_TEST=38cf80a4-be1b-4532-8781-f9b2ef706578 vinext dev --port 27018",
    "test:bdd": "bunx playwright test",
    "gate:security": "bun run scripts/gate-security.ts",
    "verify:test-db": "bun run --env-file=.env --env-file=.env.e2e scripts/verify-test-db.ts",
    "prepare": "husky"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@tailwindcss/postcss": "^4.2.1",
    "@types/bun": "latest",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "eslint": "9",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "shadcn": "^3.8.5",
    "tailwindcss": "^4.2.1",
    "typescript": "^5.0.0",
    "typescript-eslint": "^8.0.0",
    "vite": "^7.3.2"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.49",
    "@ai-sdk/openai": "^3.0.36",
    "@hono/node-server": "^1.19.13",
    "@nocoo/next-ai": "^0.2.1",
    "ai": "^6.0.104",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "hono": "^4.12.12",
    "lucide-react": "^0.575.0",
    "next": "^16.2.1",
    "next-auth": "^5.0.0-beta.30",
    "radix-ui": "^1.4.3",
    "react": "^19.2.4",
    "react-day-picker": "^9.14.0",
    "react-dom": "^19.2.4",
    "react-markdown": "^10.1.0",
    "recharts": "^3.7.0",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0",
    "vinext": "^0.0.9"
  },
  "overrides": {
    "hono": "^4.12.12",
    "@hono/node-server": "^1.19.13",
    "express-rate-limit": "^8.2.2",
    "flatted": "^3.4.0",
    "serialize-javascript": "^7.0.5",
    "brace-expansion": "^2.0.2",
    "path-to-regexp": "^8.4.0",
    "picomatch": "^4.0.4",
    "srvx": "^0.11.13"
  }
}
