{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "gecko",
  "main": ".open-next/worker.js",
  "compatibility_date": "2025-09-23",
  "compatibility_flags": ["nodejs_compat"],
  // Paid Workers tier. SSR + next-auth + LLM-streaming routes occasionally
  // need more than the 50 ms default. CPU is wall-clock-of-execution only —
  // time awaiting fetch() to Anthropic/OpenAI does not count.
  "limits": {
    "cpu_ms": 30000
  },
  "assets": {
    "binding": "ASSETS",
    "directory": ".open-next/assets"
  },
  "observability": {
    "enabled": true
  },
  // Native D1 binding — replaces the HTTP API path for production traffic.
  // Replace `database_id` with the production database ID before first deploy.
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "gecko-prod",
      "database_id": "178cd509-8ed8-49c4-993a-08c1c5fc36db"
    }
  ]
}
